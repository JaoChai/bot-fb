{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PROJECT_DIR}/.claude/settings.local.json\" 2>/dev/null | grep -o '\"pendingTask\"' >/dev/null && echo '[RESUME:PENDING] Found pending task - check settings.local.json and resume' || true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/load-rules.js\" 2>/dev/null || echo '[RULES] Failed to load rules from memory'",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/check-learning-review.js\" 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/detect-bug-keywords.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/check-debug-state.js\" 2>/dev/null || true",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/check-context-usage.js\" 2>/dev/null || true",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/sync-lessons.js\" 2>/dev/null || true; node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/sync-profile.js\" 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
