# API Configuration
# Local development
VITE_API_URL=http://localhost:8000/api
# Production example (MUST be updated to match your backend domain):
# VITE_API_URL=https://your-backend-domain.com/api

# Sentry Error Monitoring (Optional)
# Get your DSN from https://sentry.io - Create a React project
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Laravel Reverb WebSocket Configuration (Real-time messaging)
# IMPORTANT: Values must match backend REVERB_* settings
# Local development:
VITE_REVERB_APP_KEY=local-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Production example (Railway):
# VITE_REVERB_APP_KEY=your-secure-key-here
# VITE_REVERB_HOST=your-reverb-service.up.railway.app
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
