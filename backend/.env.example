APP_NAME=Laravel
# Environment: local, staging, or production
APP_ENV=local
APP_KEY=
# Set to true in your local .env for development debugging
APP_DEBUG=false
# Local development URL
APP_URL=http://localhost
# Production URL example (update for your deployment):
# APP_URL=https://your-backend-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcast Connection:
# - 'log': Debug only (no real-time updates)
# - 'reverb': WebSocket via Laravel Reverb (recommended for real-time)
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Queue Connection:
# - 'sync': Process immediately (blocking, for simple setups)
# - 'database': Use DB queue (recommended - requires: php artisan queue:work)
QUEUE_CONNECTION=database

# Cache Store:
# - 'database': Use DB cache (default)
# - 'file': Use file cache (for local development)
# - 'array': In-memory cache (fast, no persistence)
CACHE_STORE=database
# CACHE_PREFIX=

# Redis Configuration (OPTIONAL - not recommended due to quota limits)
# Free tiers have strict limits (e.g., Upstash 500K requests/month)
# We recommend using 'database' queue and cache instead
# REDIS_CLIENT=predis
# REDIS_HOST=your-redis-host
# REDIS_PASSWORD=your-redis-password
# REDIS_PORT=6379
# REDIS_SCHEME=tls

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# CORS Configuration
# Local development (default)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example (MUST be updated for your deployed frontend URL):
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# Multiple domains example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-domain.com

# Sanctum Configuration (enables stateful/cookie-based authentication for SPAs)
# Local development (default)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:3000
# Production example (MUST be updated to match your frontend domain):
# SANCTUM_STATEFUL_DOMAINS=your-frontend-domain.com
# Multiple domains example:
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:3000,your-frontend-domain.com

# OpenRouter API (for AI Bot responses)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Evaluation System (Model Tier Configuration)
# Force all evaluations to use premium tier (claude-3.5-sonnet)
# EVALUATION_FORCE_PREMIUM=false
# Override tier for specific metrics (budget|standard|premium)
# EVALUATION_TIER_OVERRIDE_ANSWER_RELEVANCY=premium
# EVALUATION_TIER_OVERRIDE_TASK_COMPLETION=standard
# EVALUATION_TIER_OVERRIDE_FAITHFULNESS=premium
# EVALUATION_TIER_OVERRIDE_ROLE_ADHERENCE=standard
# EVALUATION_TIER_OVERRIDE_CONTEXT_PRECISION=premium

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Reverb WebSocket Server (Real-time updates)
# IMPORTANT: Run 'php artisan reverb:start' to enable real-time features
# For local development:
REVERB_APP_ID=botfacebook-local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# REVERB_ALLOWED_ORIGINS: Hostnames only (NO protocol!)
# Reverb uses parse_url(..., PHP_URL_HOST) to extract hostname from Origin header
# So we must match hostnames, NOT full URLs
# Example: www.example.com,app.example.com
# NOT: https://www.example.com (this will fail!)
REVERB_ALLOWED_ORIGINS=localhost,localhost:5173,localhost:3000

# For production (Railway):
# REVERB_APP_ID=botfacebook-prod
# REVERB_APP_KEY=your-secure-key-here
# REVERB_APP_SECRET=your-secure-secret-here
# REVERB_HOST=reverb-production-xxxx.up.railway.app
# REVERB_PORT=443
# REVERB_SCHEME=https
# REVERB_ALLOWED_ORIGINS=your-frontend-domain.com (hostnames only, no https://)

# Embedding Configuration (uses OpenRouter API)
# Model format: provider/model-name (e.g., openai/text-embedding-3-small)
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50
# Minimum similarity score (0-1) for semantic search results
EMBEDDING_RELEVANCE_THRESHOLD=0.7

# RAG (Retrieval Augmented Generation) Configuration
RAG_THRESHOLD=0.70
RAG_MAX_RESULTS=3
RAG_MAX_CONTEXT_CHARS=4000
RAG_CONTEXT_TEMPLATE=thai
RAG_LOGGING_ENABLED=true
RAG_CACHE_TTL=60

# Hybrid Search Configuration (Semantic + Keyword with RRF)
RAG_HYBRID_ENABLED=true
RAG_RRF_K=60
RAG_CANDIDATE_MULTIPLIER=4

# Reranking Configuration (Phase 2)
# Jina AI Reranker (Recommended: Free 10M tokens, 96.30 Recall@20)
JINA_API_KEY=
RAG_RERANKING_ENABLED=false
RAG_RERANKER_PROVIDER=jina
RAG_RERANK_CANDIDATES=20
RAG_RERANK_TOP_N=5

# Alternative: Cohere Reranker (1000 free calls/month)
# COHERE_API_KEY=

# Query Enhancement Configuration (Phase 3)
# LLM-based query expansion for improved recall (+20-48%)
RAG_QUERY_ENHANCEMENT_ENABLED=false
RAG_QUERY_ENHANCEMENT_MODEL=openai/gpt-4o-mini
RAG_QUERY_MAX_VARIATIONS=3

# Sentry Error Monitoring (Optional)
# Get your DSN from https://sentry.io - Free tier: 5,000 errors/month
SENTRY_LARAVEL_DSN=
# Performance monitoring sample rate (0.0 to 1.0, 0.1 = 10% of requests)
SENTRY_TRACES_SAMPLE_RATE=0.1
